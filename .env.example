# ============================================
# 顺泰包装 - 环境变量配置
# 复制此文件为 .env 并填入真实值
# ============================================

# ============================================
# 【部署方式二选一】
#
# 方式A: ECS + Nginx (传统服务器)
#   - 适合：已有 ECS 服务器、需要后端 API
#   - 执行: ECS_HOST=xxx bash deploy-ecs.sh
#
# 方式B: OSS + CDN (推荐，纯静态最优)
#   - 适合：纯展示站、成本敏感、全球加速
#   - 执行: bash deploy-oss-cdn.sh
#   - GitHub Actions 自动部署也走此方式
# ============================================

# ========== 阿里云 OSS + CDN 配置（推荐）==========
OSS_BUCKET=your-bucket-name
OSS_REGION=oss-cn-hangzhou
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret

# CDN 加速域名（如 suntaizh.cn）
CDN_DOMAIN=suntaizh.cn

# ========== 阿里云 ECS 配置（备选）==========
# 部署到 ECS 的 SSH 配置
# 强烈建议使用 SSH Key 免密登录，不要在 .env 中保存密码！
# 配置方法：ssh-copy-id -i ~/.ssh/id_rsa.pub root@你的ECS公网IP
ECS_HOST=你的ECS公网IP
ECS_USER=root
# ECS_PASSWORD=已废弃，请使用 SSH Key
SSH_KEY=~/.ssh/id_rsa

# ========== 高德地图 API 配置 ==========
# 申请地址: https://lbs.amap.com/
AMAP_API_KEY=b20a7720ff059b990627b3de45dbf689
AMAP_SECURITY_JS_CODE=c6d8b1de04763b30d5ec3f9a2c4afb3e

# ========== QQ 客服配置 ==========
QQ_NUMBER=123456789

# ========== 企业微信配置 ==========
WX_QRCODE_URL=https://your-bucket.oss-region.aliyuncs.com/wx-qrcode.png

# ========== 站点配置 ==========
SITE_NAME=珠海市顺泰包装材料有限公司
SITE_URL=https://suntaizh.cn
